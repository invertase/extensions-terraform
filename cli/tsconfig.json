{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noImplicitReturns": true,
    "sourceMap": false,
    "rootDir": "src",
    "outDir": "lib",
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["src"]
}
